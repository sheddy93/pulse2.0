# ============================================================
# PulseHR Backend - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in the values
# NEVER commit .env files to version control
# ============================================================

# Django Secret Key (generate a new one for production)
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Debug mode (false in production)
DJANGO_DEBUG=false

# Allowed hosts (comma-separated)
# For Render: your-backend-name.onrender.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL (Render will provide this)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# CORS settings (comma-separated URLs)
# For Vercel: https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# CSRF trusted origins
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Redis URL (optional)
REDIS_URL=redis://127.0.0.1:6379/1

# Email settings
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=PulseHR <noreply@pulsehr.it>

# Stripe (optional for billing)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Sentry (optional for error monitoring)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# AI Assistant (disabled by default)
AI_ENABLED=false

# SAML SSO (disabled by default)
ENABLE_SAML=false