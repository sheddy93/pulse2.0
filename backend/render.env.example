# =============================================
# PulseHR - Render Deployment Environment
# =============================================

# Django Secret Key
DJANGO_SECRET_KEY=pulsehr-prod-secret-key-CHANGE-THIS

# Debug Mode (False in production)
DJANGO_DEBUG=False

# Allowed Hosts (comma separated)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-render-url.onrender.com

# CORS Origins (comma separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,your-frontend-url.onrender.com

# =============================================
# DATABASE (PostgreSQL on Render)
# =============================================
POSTGRES_DB=pulsehr
POSTGRES_USER=pulsehr_user
POSTGRES_PASSWORD=your-db-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =============================================
# FRONTEND URL
# =============================================
NEXT_PUBLIC_API_BASE_URL=https://your-backend-url.onrender.com/api
NEXT_PUBLIC_APP_URL=https://your-frontend-url.onrender.com

# =============================================
# SSO CONFIGURATION
# =============================================
PULSEHR_BASE_URL=https://your-backend-url.onrender.com
PULSEHR_ENTITY_ID=https://your-backend-url.onrender.com

# =============================================
# EMAIL (optional)
# =============================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend