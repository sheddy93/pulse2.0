# ============================================================
# PulseHR Frontend - Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in the values
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# ============================================================

# Backend API Base URL (must include /api suffix)
# For Render: https://your-backend-name.onrender.com/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Frontend site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI Assistant (disabled by default)
NEXT_PUBLIC_AI_ASSISTANT_ENABLED=false