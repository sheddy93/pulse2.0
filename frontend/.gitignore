# =============================================
# PulseHR - Gitignore
# =============================================

# Dependencies
node_modules/
.npm
.yarn
.pnp/
.pnp.js

# Build outputs
.next/
out/
build/
dist/

# Testing
coverage/
.nyc_output/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
.venv/

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/

# Staticfiles (if using whitenoise)
# asset-manifest.json
# service-worker.js

# Backup files
*.backup
*.bak
*.old

# Exported reports
reports/output/
exports/

# Cache
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# Misc
*.log
.vercel
.turbo

# TypeScript
*.tsbuildinfo
next-env.d.ts

# MiniMax Agent (optional)
.minimaxagent/

# Secrets (never commit these)
*.pem
*.key
credentials.json
service-account.json

.vercel
