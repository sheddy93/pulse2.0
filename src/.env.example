# Environment Configuration Template

# Base44
VITE_BASE44_APP_ID=your_app_id
BASE44_SERVICE_TOKEN=your_service_token

# Stripe
STRIPE_SECRET_KEY=sk_live_... (production) / sk_test_... (development)
STRIPE_PUBLISHABLE_KEY=pk_live_... (production) / pk_test_... (development)
STRIPE_WEBHOOK_SECRET=whsec_...

# Firebase
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_domain.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_bucket.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Database
DATABASE_URL=postgresql://user:password@host:5432/pulsehr_prod

# API
VITE_API_URL=https://api.pulsehr.app
VITE_API_TIMEOUT=30000

# Environment
NODE_ENV=production
VITE_ENV=production

# Monitoring
SENTRY_DSN=https://your-sentry-url
DATADOG_API_KEY=your_datadog_key

# Email
SMTP_HOST=smtp.provider.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_password

# Analytics
GA_ID=your_google_analytics_id
POSTHOG_KEY=your_posthog_key