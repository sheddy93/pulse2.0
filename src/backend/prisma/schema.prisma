// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  full_name     String?
  password_hash String
  role          String     @default("user")
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  // Relations
  employees           Employee[]
  companies_owned     Company[]          @relation("owner")
  companies_admin     Company[]          @relation("admins")
  leave_requests      LeaveRequest[]
  attendance_entries  AttendanceEntry[]
  documents           Document[]
  audit_logs          AuditLog[]

  @@index([email])
  @@index([role])
}

model Company {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phone         String?
  address       String?
  vat_number    String?
  owner_id      String
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  owner         User     @relation("owner", fields: [owner_id], references: [id])
  admins        User[]   @relation("admins")
  employees     Employee[]
  leave_requests LeaveRequest[]
  attendance_entries AttendanceEntry[]
  documents     Document[]
  audit_logs    AuditLog[]
  leave_balances LeaveBalance[]

  @@index([owner_id])
  @@index([is_active])
}

model Employee {
  id              String  @id @default(cuid())
  company_id      String
  user_id         String?
  first_name      String
  last_name       String
  email           String
  phone           String?
  department      String?
  position        String?
  hire_date       DateTime?
  birth_date      DateTime?
  is_active       Boolean @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  company         Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  user            User?   @relation(fields: [user_id], references: [id])
  leave_requests  LeaveRequest[]
  attendance_entries AttendanceEntry[]
  documents       Document[]
  leave_balance   LeaveBalance?

  @@index([company_id])
  @@index([email])
  @@index([is_active])
}

model LeaveRequest {
  id              String   @id @default(cuid())
  company_id      String
  employee_id     String
  user_id         String
  type            String   // vacation, permission, sick_leave
  start_date      DateTime
  end_date        DateTime
  days_count      Int
  reason          String?
  status          String   @default("pending") // pending, approved, rejected, cancelled
  approver_id     String?
  approval_date   DateTime?
  approval_notes  String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  company         Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  employee        Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  user            User @relation(fields: [user_id], references: [id])

  @@index([company_id])
  @@index([employee_id])
  @@index([status])
}

model AttendanceEntry {
  id              String   @id @default(cuid())
  company_id      String
  employee_id     String
  user_id         String
  type            String   // check_in, check_out, break_start, break_end
  timestamp       DateTime @default(now())
  latitude        Float?
  longitude       Float?
  location        String?
  notes           String?
  created_at      DateTime @default(now())

  // Relations
  company         Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  employee        Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  user            User @relation(fields: [user_id], references: [id])

  @@index([company_id])
  @@index([employee_id])
  @@index([timestamp])
}

model Document {
  id              String   @id @default(cuid())
  company_id      String
  employee_id     String?
  name            String
  type            String   // contract, offer, termination, nda, agreement
  file_url        String?
  status          String   @default("pending") // pending, signed, rejected, archived
  required_signature Boolean @default(false)
  signed_by       String?
  signed_at       DateTime?
  expiry_date     DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  company         Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  employee        Employee? @relation(fields: [employee_id], references: [id], onDelete: SetNull)

  @@index([company_id])
  @@index([employee_id])
  @@index([status])
}

model LeaveBalance {
  id                    String   @id @default(cuid())
  company_id            String
  employee_id           String   @unique
  available_leave       Int      @default(20)
  used_leave            Int      @default(0)
  available_permissions Int      @default(8)
  used_permissions      Int      @default(0)
  year                  Int
  notes                 String?
  updated_at            DateTime @updatedAt

  // Relations
  company               Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  employee              Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, year])
  @@index([company_id])
}

model AuditLog {
  id              String   @id @default(cuid())
  company_id      String
  user_id         String
  action          String   // create, update, delete, approve, reject
  entity_type     String   // Employee, LeaveRequest, Document
  entity_id       String
  changes         Json?
  ip_address      String?
  user_agent      String?
  created_at      DateTime @default(now())

  // Relations
  company         Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  user            User @relation(fields: [user_id], references: [id])

  @@index([company_id])
  @@index([user_id])
  @@index([created_at])
}