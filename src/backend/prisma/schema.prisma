// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === AUTH & USERS ===
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  fullName          String?
  role              String    @default("user") // super_admin, company_owner, company_admin, hr_manager, manager, employee, consultant, etc.
  companyId         String?
  company           Company?  @relation(fields: [companyId], references: [id])
  profile           UserProfile?
  
  // Auth & Security
  twoFactorSecret   String?
  twoFactorEnabled  Boolean   @default(false)
  lastLogin         DateTime?
  mustChangePassword Boolean  @default(false)
  isActive          Boolean   @default(true)

  // Relations
  leaveRequests     LeaveRequest[]
  overtimeRequests  OvertimeRequest[]
  expenses          ExpenseReimbursement[]
  documents         Document[]
  announcements     Announcement[]
  messages          CompanyMessage[]
  notifications     Notification[]
  skills            EmployeeSkill[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([companyId])
  @@index([email])
}

model UserProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  phone           String?
  address         String?
  city            String?
  postalCode      String?
  country         String?
  department      String?
  jobTitle        String?
  hireDate        DateTime?
  birthDate       DateTime?
  profileImageUrl String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// === COMPANIES ===
model Company {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  phone             String?
  website           String?
  
  // Address
  address           String?
  city              String?
  postalCode        String?
  country           String?
  
  // Settings
  logoUrl           String?
  industryType      String?
  employeeCount     Int?
  timezone          String    @default("UTC")
  language          String    @default("it")
  
  // Subscription
  stripeCustomerId  String?
  subscriptionId    String?
  subscriptionPlan  String    @default("startup")
  subscriptionStatus String   @default("trial") // trial, active, canceled, past_due
  trialEndsAt       DateTime?
  billingCycleStart DateTime?
  billingCycleEnd   DateTime?
  
  // Features
  maxEmployees      Int       @default(10)
  featureBiometric  Boolean   @default(false)
  featureGeofence   Boolean   @default(false)
  featurePayroll    Boolean   @default(false)
  featureApiAccess  Boolean   @default(false)
  
  isActive          Boolean   @default(true)
  
  // Relations
  users             User[]
  employees         Employee[]
  locations         CompanyLocation[]
  departments       Department[]
  shifts            Shift[]
  announcements     Announcement[]
  documents         Document[]
  settings          CompanySettings?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([stripeCustomerId])
}

model CompanySettings {
  id                String    @id @default(cuid())
  companyId         String    @unique
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Notification settings
  pushNotifications Boolean   @default(true)
  emailNotifications Boolean  @default(true)
  
  // Geofence
  geofenceEnabled   Boolean   @default(false)
  geofenceRadius    Int       @default(100) // meters
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model CompanyLocation {
  id                String    @id @default(cuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  name              String
  address           String?
  latitude          Float?
  longitude         Float?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([companyId])
}

model Department {
  id                String    @id @default(cuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  name              String
  description       String?
  managerId         String?
  
  employees         Employee[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([companyId])
  @@unique([companyId, name])
}

// === EMPLOYEES ===
model Employee {
  id                String    @id @default(cuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  firstName         String
  lastName          String
  email             String
  phone             String?
  
  jobTitle          String?
  department        String?
  departmentId      String?
  dept              Department? @relation(fields: [departmentId], references: [id])
  
  hireDate          DateTime?
  birthDate         DateTime?
  
  employmentType    String    @default("full_time") // full_time, part_time, contract, intern
  contractStatus    String    @default("active") // active, probation, on_leave, terminated
  
  // Compensation
  salary            Float?
  currency          String    @default("EUR")
  
  // Personal
  profileImageUrl   String?
  address           String?
  city              String?
  country           String?
  
  isActive          Boolean   @default(true)
  
  // Relations
  attendances       AttendanceEntry[]
  timeEntries       TimeEntry[]
  leaveRequests     LeaveRequest[]
  leaveBalance      LeaveBalance?
  overtimeRequests  OvertimeRequest[]
  expenses          ExpenseReimbursement[]
  skills            EmployeeSkill[]
  contracts         EmployeeContract[]
  documents         Document[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([companyId])
  @@index([email])
  @@unique([companyId, email])
}

// === ATTENDANCE ===
model AttendanceEntry {
  id                String    @id @default(cuid())
  companyId         String
  employeeId        String
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  type              String    @default("clock_in") // clock_in, clock_out, break_start, break_end
  timestamp         DateTime
  
  latitude          Float?
  longitude         Float?
  geoAccuracy       Float?
  
  deviceInfo        String?
  isOffsite         Boolean   @default(false)
  notes             String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([employeeId])
  @@index([companyId])
  @@index([timestamp])
}

model TimeEntry {
  id                String    @id @default(cuid())
  companyId         String
  employeeId        String
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  date              DateTime
  startTime         String
  endTime           String
  duration          Float     // hours
  
  category          String    @default("work") // work, break, training, meeting
  notes             String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([employeeId])
  @@index([date])
}

// === LEAVE & TIME OFF ===
model LeaveRequest {
  id                String    @id @default(cuid())
  companyId         String
  employeeId        String
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  type              String    @default("vacation") // vacation, sick_leave, personal, unpaid
  startDate         DateTime
  endDate           DateTime
  durationDays      Int
  
  reason            String?
  status            String    @default("pending") // pending, approved, rejected, cancelled
  
  approvedBy        String?
  approvedAt        DateTime?
  rejectedReason    String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([companyId])
}

model LeaveBalance {
  id                String    @id @default(cuid())
  employeeId        String    @unique
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyId         String
  
  year              Int
  
  availableVacation Float     @default(20)
  usedVacation      Float     @default(0)
  
  availableSick     Float     @default(8)
  usedSick          Float     @default(0)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// === OVERTIME ===
model OvertimeRequest {
  id                String    @id @default(cuid())
  companyId         String
  employeeId        String
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  date              DateTime
  hours             Float
  reason            String?
  
  status            String    @default("pending") // pending, approved, rejected
  approvedBy        String?
  approvedAt        DateTime?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([employeeId])
  @@index([status])
}

// === EXPENSES ===
model ExpenseReimbursement {
  id                String    @id @default(cuid())
  companyId         String
  employeeId        String
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  amount            Float
  currency          String    @default("EUR")
  category          String    @default("other") // travel, meals, accommodation, equipment, training, other
  description       String?
  
  receiptUrl        String?
  
  expenseDate       DateTime
  status            String    @default("draft") // draft, submitted, approved, rejected, paid
  
  approverEmail     String?
  approvedAt        DateTime?
  approvalNotes     String?
  
  paidAt            DateTime?
  paymentMethod     String    @default("bank_transfer")
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([companyId])
}

// === DOCUMENTS ===
model Document {
  id                String    @id @default(cuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId        String?
  employee          Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  title             String
  type              String    @default("contract") // contract, offer_letter, nda, certificate, other
  
  fileUrl           String
  fileName          String
  fileSize          Int
  
  uploadedBy        String
  
  requiresSignature Boolean   @default(false)
  signedBy          String?
  signedAt          DateTime?
  signatureUrl      String?
  
  expiryDate        DateTime?
  status            String    @default("active") // active, expired, archived
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([expiryDate])
}

model EmployeeContract {
  id                String    @id @default(cuid())
  employeeId        String
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyId         String
  
  type              String    @default("permanent")
  startDate         DateTime
  endDate           DateTime?
  
  fileUrl           String
  fileName          String
  
  status            String    @default("active") // active, expired, archived
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([employeeId])
}

// === SHIFTS ===
model Shift {
  id                String    @id @default(cuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  name              String
  startTime         String    // HH:mm
  endTime           String    // HH:mm
  breakDuration     Int       @default(0) // minutes
  
  isActive          Boolean   @default(true)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([companyId])
}

// === SKILLS ===
model EmployeeSkill {
  id                String    @id @default(cuid())
  employeeId        String
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyId         String
  
  skillName         String
  proficiency       String    @default("intermediate") // beginner, intermediate, advanced, expert
  yearsOfExperience Int?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([employeeId])
  @@unique([employeeId, skillName])
}

// === ANNOUNCEMENTS ===
model Announcement {
  id                String    @id @default(cuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy         String
  creator           User      @relation(fields: [createdBy], references: [id])
  
  title             String
  content           String
  
  priority          String    @default("normal") // low, normal, high, urgent
  targetAudience    String    @default("all") // all, department, group, individual
  
  publishedAt       DateTime
  expiresAt         DateTime?
  
  attachments       String[]  @default([])
  readBy            String[]  @default([])
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([companyId])
}

// === MESSAGES ===
model CompanyMessage {
  id                String    @id @default(cuid())
  companyId         String
  senderEmail       String
  sender            User      @relation(fields: [senderEmail], references: [email])
  
  subject           String
  content           String
  
  messageType       String    @default("notification")
  recipientType     String    @default("individual")
  recipientEmails   String[]
  
  priority          String    @default("normal")
  readBy            String[]  @default([])
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([companyId])
  @@index([senderEmail])
}

// === NOTIFICATIONS ===
model Notification {
  id                String    @id @default(cuid())
  userEmail         String
  user              User      @relation(fields: [userEmail], references: [email])
  
  type              String    // leave_approved, expense_submitted, document_uploaded, etc.
  title             String
  message           String
  
  resourceType      String?   // LeaveRequest, Document, etc.
  resourceId        String?
  
  read              Boolean   @default(false)
  readAt            DateTime?
  
  createdAt         DateTime  @default(now())

  @@index([userEmail])
  @@index([read])
}

// === PAYMENTS & BILLING ===
model StripePayment {
  id                String    @id @default(cuid())
  companyId         String
  
  stripeSessionId   String    @unique
  stripePaymentId   String?   @unique
  stripeCustomerId  String?
  
  amount            Int       // cents
  currency          String    @default("eur")
  
  status            String    @default("pending") // pending, succeeded, failed, canceled
  
  planId            String?
  billingCycle      String?
  
  failureReason     String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([companyId])
  @@index([stripePaymentId])
}

// === AUDIT LOG ===
model AuditLog {
  id                String    @id @default(cuid())
  companyId         String
  userEmail         String
  
  action            String    // user_created, document_signed, leave_approved, etc.
  resourceType      String?   // User, Document, LeaveRequest, etc.
  resourceId        String?
  
  changes           Json?     // delta of changes
  
  ipAddress         String?
  userAgent         String?
  
  createdAt         DateTime  @default(now())

  @@index([companyId])
  @@index([userEmail])
  @@index([createdAt])
}