{
  "name": "Document",
  "type": "object",
  "properties": {
    "company_id": { "type": "string" },
    "employee_id": { "type": "string" },
    "title": { "type": "string" },
    "doc_type": { "type": "string", "enum": ["contratto", "busta_paga", "certificato", "corso", "altro"] },
    "file_url": { "type": "string" },
    "uploaded_by": { "type": "string" },
    "visibility": { "type": "string", "enum": ["employee", "company", "consultant", "all"], "default": "all" },
    "expiry_date": { "type": "string", "format": "date" },
    "notes": { "type": "string" },
    "status": { "type": "string", "enum": ["in_revisione", "approvato", "rifiutato"], "default": "in_revisione" },
    "signature_required": { "type": "boolean", "default": false },
    "signature_status": { "type": "string", "enum": ["pending", "signed", "rejected"] },
    "created_date": { "type": "string", "format": "date-time" },
    "is_deleted": { "type": "boolean", "default": false },
    "deleted_at": { "type": "string", "format": "date-time" }
  },
  "required": ["company_id", "title", "doc_type", "file_url"]
}