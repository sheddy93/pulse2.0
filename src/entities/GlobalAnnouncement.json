{
  "name": "GlobalAnnouncement",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["info", "warning", "success", "urgent"],
      "default": "info"
    },
    "target_audience": {
      "type": "string",
      "enum": ["all", "companies", "consultants", "employees"],
      "default": "all"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "show_on_landing": {
      "type": "boolean",
      "default": false
    },
    "published_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "priority": {
      "type": "number",
      "minimum": 1,
      "maximum": 10
    }
  },
  "required": ["title", "content"]
}