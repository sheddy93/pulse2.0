{
  "name": "OnboardingProgress",
  "type": "object",
  "properties": {
    "employee_id": {
      "type": "string"
    },
    "employee_name": {
      "type": "string"
    },
    "employee_email": {
      "type": "string"
    },
    "company_id": {
      "type": "string"
    },
    "current_step": {
      "type": "number",
      "default": 1,
      "description": "Step attuale (1-4)"
    },
    "step_1_profile_completed": {
      "type": "boolean",
      "default": false,
      "description": "Profilo completato"
    },
    "step_2_contract_signed": {
      "type": "boolean",
      "default": false,
      "description": "Contratto firmato"
    },
    "step_2_contract_url": {
      "type": "string"
    },
    "step_2_signed_at": {
      "type": "string"
    },
    "step_3_documents_uploaded": {
      "type": "boolean",
      "default": false,
      "description": "Documenti caricati"
    },
    "step_3_documents": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["id", "tax_code", "insurance", "medical"]
          },
          "url": {
            "type": "string"
          },
          "uploaded_at": {
            "type": "string"
          }
        }
      }
    },
    "step_4_review_completed": {
      "type": "boolean",
      "default": false,
      "description": "Revisione HR completata"
    },
    "overall_progress": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Percentuale avanzamento complessivo"
    },
    "status": {
      "type": "string",
      "enum": ["in_progress", "completed", "on_hold"],
      "default": "in_progress"
    },
    "hr_notes": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "completed_at": {
      "type": "string"
    }
  },
  "required": [
    "employee_id",
    "company_id",
    "employee_email"
  ]
}