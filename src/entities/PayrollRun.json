{
  "name": "PayrollRun",
  "type": "object",
  "properties": {
    "company_id": { "type": "string" },
    "period_month": { "type": "number" },
    "period_year": { "type": "number" },
    "status": { "type": "string", "enum": ["draft", "processing", "completed", "archived"], "default": "draft" },
    "employee_count": { "type": "number" },
    "gross_total": { "type": "number" },
    "net_total": { "type": "number" },
    "created_by": { "type": "string" },
    "completed_at": { "type": "string", "format": "date-time" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "required": ["company_id", "period_month", "period_year"]
}