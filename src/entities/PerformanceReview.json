{
  "name": "PerformanceReview",
  "type": "object",
  "properties": {
    "company_id": { "type": "string" },
    "employee_id": { "type": "string" },
    "employee_email": { "type": "string" },
    "employee_name": { "type": "string" },
    "review_period": { "type": "string", "description": "es: 2025-Q1" },
    "reviewer_email": { "type": "string" },
    "reviewer_name": { "type": "string" },
    "rating": { "type": "number", "minimum": 1, "maximum": 5 },
    "summary": { "type": "string" },
    "strengths": { "type": "string" },
    "areas_for_improvement": { "type": "string" },
    "goals": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "submitted", "acknowledged"], "default": "draft" },
    "submitted_at": { "type": "string", "format": "date-time" },
    "acknowledged_at": { "type": "string", "format": "date-time" },
    "is_deleted": { "type": "boolean", "default": false },
    "deleted_at": { "type": "string", "format": "date-time" }
  },
  "required": ["company_id", "employee_id", "employee_email", "review_period", "reviewer_email"]
}