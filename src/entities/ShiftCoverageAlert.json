{
  "name": "ShiftCoverageAlert",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string"
    },
    "alert_type": {
      "type": "string",
      "enum": ["overlap", "uncovered", "low_coverage"],
      "description": "Tipo di alert"
    },
    "alert_date": {
      "type": "string",
      "format": "date"
    },
    "start_time": {
      "type": "string",
      "pattern": "^[0-2][0-9]:[0-5][0-9]$"
    },
    "end_time": {
      "type": "string",
      "pattern": "^[0-2][0-9]:[0-5][0-9]$"
    },
    "location_id": {
      "type": "string"
    },
    "location_name": {
      "type": "string"
    },
    "affected_employees": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "employee_id": {
            "type": "string"
          },
          "employee_name": {
            "type": "string"
          },
          "shift_assignment_id": {
            "type": "string"
          }
        }
      },
      "description": "Dipendenti coinvolti nell'alert"
    },
    "required_coverage": {
      "type": "number",
      "description": "Numero minimo di dipendenti necessari"
    },
    "current_coverage": {
      "type": "number",
      "description": "Numero attuale di dipendenti assegnati"
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "default": "medium"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "reviewed", "resolved", "closed"],
      "default": "pending"
    },
    "resolution_notes": {
      "type": "string"
    },
    "reviewed_by": {
      "type": "string"
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "company_id",
    "alert_type",
    "alert_date",
    "location_id"
  ]
}