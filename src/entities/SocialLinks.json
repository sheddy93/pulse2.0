{
  "name": "SocialLinks",
  "type": "object",
  "properties": {
    "platform": {
      "type": "string",
      "enum": ["linkedin", "twitter", "facebook", "instagram", "github", "youtube"],
      "description": "Social media platform"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "icon_name": {
      "type": "string",
      "description": "Lucide React icon name"
    },
    "display_order": {
      "type": "number",
      "default": 0
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": ["platform", "url", "icon_name"]
}