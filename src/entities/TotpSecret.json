{
  "name": "TotpSecret",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "Email dell'utente"
    },
    "secret": {
      "type": "string",
      "description": "Base32 encoded secret per TOTP"
    },
    "qr_code_url": {
      "type": "string",
      "description": "URL QR code per scanner mobile"
    },
    "is_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Se 2FA è attivo"
    },
    "backup_codes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "used": {
            "type": "boolean",
            "default": false
          },
          "used_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "default": [],
      "description": "Codici di backup per recupero account"
    },
    "enabled_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_verified_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["user_email", "secret"]
}