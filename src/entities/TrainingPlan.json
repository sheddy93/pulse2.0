{
  "name": "TrainingPlan",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string"
    },
    "employee_id": {
      "type": "string"
    },
    "employee_name": {
      "type": "string"
    },
    "employee_email": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "description": "Nome del piano di formazione"
    },
    "description": {
      "type": "string"
    },
    "plan_type": {
      "type": "string",
      "enum": ["onboarding", "skill_development", "compliance", "career_growth", "custom"],
      "default": "custom"
    },
    "courses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "course_id": {
            "type": "string"
          },
          "course_name": {
            "type": "string"
          },
          "mandatory": {
            "type": "boolean",
            "default": false
          },
          "target_completion_date": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "type": "string",
            "enum": ["not_started", "in_progress", "completed", "overdue"]
          },
          "completion_date": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "skills_target": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "skill_name": {
            "type": "string"
          },
          "current_level": {
            "type": "string",
            "enum": ["beginner", "intermediate", "advanced", "expert"]
          },
          "target_level": {
            "type": "string",
            "enum": ["beginner", "intermediate", "advanced", "expert"]
          },
          "deadline": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "created_by": {
      "type": "string"
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "end_date": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "completed", "cancelled"],
      "default": "draft"
    },
    "progress_percentage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "default": 0
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "company_id",
    "employee_id",
    "employee_email",
    "title"
  ]
}