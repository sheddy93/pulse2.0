{
  "name": "WorkConversation",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string"
    },
    "participant_1_email": {
      "type": "string"
    },
    "participant_1_name": {
      "type": "string"
    },
    "participant_2_email": {
      "type": "string"
    },
    "participant_2_name": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    },
    "last_message": {
      "type": "string"
    },
    "last_message_at": {
      "type": "string",
      "format": "date-time"
    },
    "unread_count_p1": {
      "type": "number",
      "default": 0
    },
    "unread_count_p2": {
      "type": "number",
      "default": 0
    },
    "status": {
      "type": "string",
      "enum": ["active", "archived", "closed"],
      "default": "active"
    }
  },
  "required": ["company_id", "participant_1_email", "participant_2_email"]
}