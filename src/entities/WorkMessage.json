{
  "name": "WorkMessage",
  "type": "object",
  "properties": {
    "conversation_id": {
      "type": "string",
      "description": "ID della conversazione"
    },
    "sender_email": {
      "type": "string"
    },
    "sender_name": {
      "type": "string"
    },
    "receiver_email": {
      "type": "string"
    },
    "company_id": {
      "type": "string"
    },
    "content": {
      "type": "string",
      "description": "Testo del messaggio"
    },
    "message_type": {
      "type": "string",
      "enum": ["text", "request", "approval", "file"],
      "default": "text"
    },
    "request_type": {
      "type": "string",
      "enum": ["leave", "overtime", "expense", "document", "other"],
      "description": "Tipo richiesta se message_type=request"
    },
    "request_id": {
      "type": "string",
      "description": "ID della richiesta collegata"
    },
    "request_data": {
      "type": "object",
      "description": "Snapshot dati richiesta"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      },
      "default": []
    },
    "read_at": {
      "type": "string",
      "format": "date-time"
    },
    "sent_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["conversation_id", "sender_email", "content", "company_id"]
}